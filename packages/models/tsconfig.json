{
  "compileOnSave": false,
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "experimentalDecorators": true,
    "strictNullChecks": false,
    "rootDir": "src/",
    "outDir": "build",
    "inlineSourceMap": true,
    "noImplicitAny": false,
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "es2017",
    //"module": "es6",
    "noEmitOnError": true,
    "lib": [
      "es2017"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
  ]
}