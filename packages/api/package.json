{
  "name": "@battles/api",
  "version": "0.4.2",
  "description": "API using AWS Lambda, DynamoDB, and CDK",
  "author": "Tom Wright",
  "repository": "https://github.com/tomwwright/graph-battles.git",
  "license": "MIT",
  "keywords": [
    "typescript",
    "boilerplate",
    "esbuild"
  ],
  "main": "./dist/tsc/main.js",
  "types": "./dist/tsc/main.d.ts",
  "browser": "./dist/esbuild/browser.js",
  "bin": {
    "my-cli-tool": "./dist/esbuild/cli.js"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "test": "jest",
    "clean": "rm -rf dist build package",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "@typescript-eslint/parser": "^4.19.0",
    "esbuild": "^0.11.11",
    "eslint": "^7.22.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.36.0",
    "@codegenie/serverless-express": "^5.0.0-beta.2",
    "cors": "^2.8.5",
    "dynamodb-onetable": "^1.9.0",
    "express": "^4.17.1"
  }
