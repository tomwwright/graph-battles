{
  "compileOnSave": false,
  "compilerOptions": {
    "experimentalDecorators": true,
    "strictNullChecks": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": "src/",
    "rootDir": "src/",
    "outDir": "build/es5",
    "inlineSourceMap": true,
    "noImplicitAny": false,
    "moduleResolution": "node10",
    "skipLibCheck": true,
    "target": "es5",
    //"module": "es6",
    "jsx": "react",
    "noEmitOnError": true,
    "lib": [
      "es2019",
      "dom"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "references": [
    {
      "path": "../models"
    }
  ]
}